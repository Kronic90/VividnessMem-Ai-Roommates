# AI Roommates — only tracked files are committed
# This .gitignore blocks everything, we use 'git add -f' for project files.

# Ignore everything by default
*

# Then whitelist project files
!.gitignore
!ai_roommates.py
!world_tools.py
!web_tools.py
!message_board.py
!memory_aria.py
!memory_rex.py
!task_memory.py
!requirements.txt
!README.md
!LICENSE
!tests/
!tests/**
!benchmarks/
!benchmarks/**
!memory_snapshots/
!memory_snapshots/**
!standalone memory/
!standalone memory/**
!benchmark_vividness.py
!benchmark_results/
!benchmark_results/**
# Exclude memory data stores from benchmark_results
benchmark_results/*_vividmem_data/
benchmark_results/*_specmem_data/
benchmark_results/*_combined_data/
